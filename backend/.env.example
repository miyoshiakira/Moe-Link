# ============================================================
# Azure OpenAI (GPT-4o Realtime API)
# ============================================================
# Azure Portal > リソース > キーとエンドポイント から取得
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-api-key>
# Azure OpenAI Studio でデプロイした gpt-4o-realtime-preview のデプロイ名
AZURE_OPENAI_DEPLOYMENT=gpt-4o-realtime-preview
AZURE_OPENAI_API_VERSION=2024-12-17

# ============================================================
# Azure AI Search
# ============================================================
# Azure Portal > AI Search リソース > 概要 から取得
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
# Azure Portal > AI Search > キー から取得（管理者キー）
AZURE_SEARCH_API_KEY=<your-search-api-key>

# ============================================================
# Server
# ============================================================
PORT=3001
FRONTEND_URL=http://localhost:5173
